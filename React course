23. React Reducer - 
manages state in centralized way, t have clear separation between ui and state logic.
reducer - how its done
so we have components -  App.js and that has TiceketList, TicketItem
and then we will have our TiceketReducer.js - that has actions like AddTicket, Delete Ticket and update ticket.,
our components dispatch the actions to reducer, which handles them.
import {reactReducer} from "react";

const [state, dispatch] = useReducer(ticketReducer, initialState);
useReducer is a react hook.

now inside our TicketReducer - 
export default function ticketReducer(state, action) {  //action we want to handle inside this reducer.
  switch(action.type) {
    case  "ADD_TICKET":
      return { ...state, tickets: [...state.tickets, action.paylod]};
//reducer returns a state , we create a nw state by copying over the state(... state). sate is immutable so we dont modify existing state but create copy of it. and we are 
modifying state by adding action.payload(that is currnet ticket form data) to existying tickets.
    case "UPDATE_TICKET:
      return { ...state, tickets: state.tickets.map((ticket) => 
            ticket.id === action.paylod.id ? action.payload : ticket   // so we find the ticket, then we update it , or simply take the ticket.
            ),
        };
    case "DELETE_TICKET":
      return {...state, tickets: state.tickets.filter((ticket) =>
              ticket.id !== action.payload.id
            ),
      };
    case "SET_EDITING_TICKET":
      return {
        ...state, editingTicket: action.payload
    }
    case "CLEAR_EDITING_TICKET":
      return {
        ...state, editingTicket: null
      }
    default:
      return state;
  }
}


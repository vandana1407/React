24. for sorting tickets based on priority high to low
we will create a utilities folder and inside it we have logic to sort

export const sortTicket = (tickets, preference) => {
  switch(preference) {
      case "High to Low":
        return [...tickets].sort((a,b) => b.priority.localeCompare(a.priority));
      case "Low to High":
        return [...tickets].sort((a,b) => a.priority.localeCompare(b.priority));
      case default:
        return tickets;
}
};

